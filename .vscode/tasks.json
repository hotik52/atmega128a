{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Upload to ATmega128A (AVRISP mkII)",
        "type": "shell",
        "command": "/usr/bin/avrdude",
        "args": [
          "-C", "/etc/avrdude.conf",
          "-v",
          "-u",
          "-p", "atmega128a",
          "-c", "avrisp2",
          "-P", "/dev/ttyUSB0",
          "-b", "115200",
          "-U", "flash:w:build/atmega128a.hex:i"
        ]        
      }
    ]
  }